# Next.js 14 ARVION Local Environment Variables

# Database Setup (SQLite)
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate_a_random_32_character_string_for_production"

# OAuth Providers (Google)
# Get credentials from the Google Cloud Console (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Gemini AI Platform API Key
# Get a free key from Google AI Studio (https://aistudio.google.com)
GOOGLE_API_KEY="AIzaSyYourGeminiApiKeyHere"
